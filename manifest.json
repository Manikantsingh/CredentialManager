{
  "manifest_version": 3,
  "name": "CredManager",
  "version": "1.0.0",
  "description": "Personal credentials manager with AES-GCM 256 encryption and Google Drive sync.",
  "minimum_chrome_version": "102",
  "permissions": ["identity", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CredManager"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon48.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
